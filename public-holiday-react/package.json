{
  "name": "public-holiday-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:docker": "VITE_BUILD_TARGET=docker vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "docker:build": "docker build -t public-holiday-react:local --build-arg VITE_BUILD_TARGET=docker .",
    "docker:run": "docker run --name public-holiday-react --rm -p 8080:80 public-holiday-react:local"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}